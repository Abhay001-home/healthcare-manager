# ─────────────────────────────────────────────
# DATABASE  (MongoDB)
# ─────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/healthcare_db
# MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/healthcare_db?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# AUTH  (JSON Web Token)
# ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# ANTHROPIC  (LLM)
# ─────────────────────────────────────────────
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# EMAIL  — choose ONE provider
# ─────────────────────────────────────────────
## Option A: SMTP / Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Meridian Clinic <you@gmail.com>"

## Option B: SendGrid (comment out SMTP_* and uncomment these)
# SENDGRID_API_KEY=SG.REPLACE_ME
# MAIL_FROM="Meridian Clinic <noreply@yourdomain.com>"

# ─────────────────────────────────────────────
# GOOGLE CALENDAR  (OAuth 2.0)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_STRING

# ─────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────
SLOT_HOLD_SECONDS=120
REMINDER_CRON=0 8 * * *
LOG_LEVEL=info
